# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Raw dataset — large, and not something you want versioned in git anyway
Audiodata/
data/raw/

# Cached/generated features — regenerated by feature_extraction.py, not source
*.npy
features.csv
metadata.csv

# Training artifacts — logs and checkpoints are usually large binaries;
# regenerable by re-running train.py, and .pt files bloat git history fast
logs/
checkpoints/*.pt

# Test cache
.pytest_cache/

# Editor/OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db

# Environment variables / secrets, if you ever add any
.env
